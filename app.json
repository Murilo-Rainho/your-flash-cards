{
  "expo": {
    "name": "Your Flash Cards",
    "slug": "your-flash-cards",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "yourflashcards",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.veploy.yourflashcards",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2563EB"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.MODIFY_AUDIO_SETTINGS"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Permita que o Your Flash Cards grave audios para seus cards."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o Your Flash Cards acesse imagens para seus cards.",
          "cameraPermission": "Permita que o Your Flash Cards use a camera para imagens dos cards.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6e9d366d-9148-41c6-94ca-fee36807bff2"
      }
    },
    "owner": "murilo-rainho"
  }
}
